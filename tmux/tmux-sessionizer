#!/usr/bin/env bash
# tmux-sessionizer — ThePrimeagen-style project switcher
# Usage: tmux-sessionizer [path]
# If no path given, uses fzf to pick from project directories.

# ── Project directories to search ──
# Add your project root directories here
PROJECT_DIRS=(
    ~/projects
    ~/work
    ~/.dotfiles
)

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # Build list of directories to search (only ones that exist)
    search_dirs=()
    for dir in "${PROJECT_DIRS[@]}"; do
        [[ -d "$dir" ]] && search_dirs+=("$dir")
    done

    if [[ ${#search_dirs[@]} -eq 0 ]]; then
        echo "No project directories found. Edit PROJECT_DIRS in tmux-sessionizer."
        exit 1
    fi

    selected=$(find "${search_dirs[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$selected_name"

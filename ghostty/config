# ─────────────────────────────────────────────
# Ghostty Configuration
# ─────────────────────────────────────────────

# Font
font-family = FiraMono Nerd Font
font-size = 16

# Theme (matches Catppuccin Mocha)
theme = Catppuccin Mocha

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = true
window-width = 9999
window-height = 9999
macos-titlebar-style = tabs
macos-option-as-alt = true

# Shell
shell-integration = zsh

# Cursor
cursor-style = block
cursor-style-blink = false

# ── Splits (using tmux now, but keep Ghostty splits as backup) ──
# NOTE: Primary splits/sessions handled by tmux (prefix=C-a)
# Ghostty splits kept for quick one-off use
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface

# ── Tabs ──
keybind = cmd+t=new_tab
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3

# Scrollback
scrollback-limit = 10000

# Confirm close (prevents accidental close of nvim sessions)
confirm-close-surface = true

# ─────────────────────────────────────────────
# Ghostty Configuration
# ─────────────────────────────────────────────

# Font
font-family = FiraCode Nerd Font Mono
font-size = 16

# Theme (matches Catppuccin Mocha)
theme = Catppuccin Mocha

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = true
window-width = 9999
window-height = 9999
macos-titlebar-style = tabs
macos-option-as-alt = true

# Shell
shell-integration = zsh

# Cursor
cursor-style = block
cursor-style-blink = false

# ── Splits (using tmux now, but keep Ghostty splits as backup) ──
# NOTE: Primary splits/sessions handled by tmux (prefix=C-a)
# Ghostty splits kept for quick one-off use
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface

# ── tmux window switching (Cmd+number feels native on macOS) ──
# Unbind Ghostty's default tab switching, then send C-a + number to tmux
keybind = cmd+physical:one=text:\x01\x31
keybind = cmd+physical:two=text:\x01\x32
keybind = cmd+physical:three=text:\x01\x33
keybind = cmd+physical:four=text:\x01\x34
keybind = cmd+physical:five=text:\x01\x35
keybind = cmd+physical:six=text:\x01\x36
keybind = cmd+physical:seven=text:\x01\x37
keybind = cmd+physical:eight=text:\x01\x38
keybind = cmd+physical:nine=text:\x01\x39

# ── Tabs (Ghostty native, use Cmd+T to create) ──
keybind = cmd+t=new_tab

# Scrollback
scrollback-limit = 10000

# Confirm close (prevents accidental close of nvim sessions)
confirm-close-surface = true
